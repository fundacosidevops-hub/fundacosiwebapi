{
    "openapi": "3.0.0",
    "info": {
        "title": "Fundacosi",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000/",
            "description": "Servidor Local"
        },
        {
            "url": "https://webapi.fundacosixxi.com",
            "description": "Servidor Producción"
        }
    ],
    "paths": {
        "/api/v1/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login usuario",
                "operationId": "da2ca4d7a5cdec77b8b45a20373535cb",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "test@fundacosixxi.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login exitoso"
                    },
                    "401": {
                        "description": "Credenciales inválidas"
                    }
                }
            }
        },
        "/api/v1/saveUser": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Guardar usuario",
                "operationId": "31c02a2fbfefc40ae29d87aef7307687",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "role",
                                    "positionsId",
                                    "email"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Juan Perez"
                                    },
                                    "role": {
                                        "type": "string",
                                        "example": "Administrador"
                                    },
                                    "positionsId": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "juan@fundacosixxi.com"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "8095551234"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuario creado correctamente"
                    },
                    "400": {
                        "description": "Datos inválidos"
                    },
                    "401": {
                        "description": "No autorizado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/profile": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Obtener perfil del usuario autenticado",
                "operationId": "e7fa93473c44547baf6183ba42322df2",
                "responses": {
                    "200": {
                        "description": "Perfil obtenido correctamente"
                    },
                    "401": {
                        "description": "No autorizado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/roles": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Obtener roles",
                "operationId": "02c0d86e2afb7eedfc4ded46d8dd1cdc",
                "responses": {
                    "200": {
                        "description": "Roles obtenidos correctamente"
                    },
                    "401": {
                        "description": "No autorizado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/positions": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Obtener posiciones",
                "operationId": "e0fe95909848168bc9cdddc8157ce195",
                "responses": {
                    "200": {
                        "description": "Roles obtenidos correctamente"
                    },
                    "401": {
                        "description": "No autorizado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Cerrar sesión",
                "operationId": "c4eddaf1a2e990cc90e4326c0d731d41",
                "responses": {
                    "200": {
                        "description": "Sesión cerrada correctamente"
                    },
                    "401": {
                        "description": "No autorizado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/billing/user-info": {
            "get": {
                "tags": [
                    "Billing"
                ],
                "summary": "Obtener datos del usuario a facturar",
                "operationId": "6eed1c09ec6e81ad19fb2978678adffb",
                "parameters": [
                    {
                        "name": "document",
                        "in": "query",
                        "description": "Documento del usuario",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "00107508525"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Datos obtenido correctamente"
                    },
                    "401": {
                        "description": "No autorizado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Endpoints de usuarios"
        },
        {
            "name": "Billing",
            "description": "Endpoints de facturas"
        }
    ]
}